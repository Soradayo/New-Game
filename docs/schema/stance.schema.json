{
  "$id": "https://new-game.local/schema/stance.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stance",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "labelKey", "descriptionKey", "effects"],
  "properties": {
    "id": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/id" },
    "labelKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" },
    "descriptionKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" },
    "effects": {
      "type": "array",
      "items": { "$ref": "https://new-game.local/schema/effect.schema.json" }
    }
  }
}
