{
  "$id": "https://new-game.local/schema/turning-point.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Turning Point",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "labelKey", "descriptionKey", "category", "weight", "ageWindow", "conditions", "choices"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9-]*$"
    },
    "labelKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" },
    "descriptionKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" },
    "category": {
      "enum": ["education", "career", "relationship", "world"]
    },
    "weight": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "ageWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minMonths", "maxMonths", "guaranteedByMonths"],
      "properties": {
        "minMonths": { "type": "number", "minimum": 0 },
        "maxMonths": { "type": "number", "minimum": 0 },
        "guaranteedByMonths": { "type": "number", "minimum": 0 }
      }
    },
    "conditions": {
      "type": "array",
      "items": { "$ref": "https://new-game.local/schema/condition.schema.json" }
    },
    "choices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "labelKey", "descriptionKey", "requirements", "outcomeSummaryKey", "effects", "grantsTags"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9-]*$"
          },
          "labelKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" },
          "descriptionKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" },
          "requirements": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["condition", "reasonKey"],
              "properties": {
                "condition": { "$ref": "https://new-game.local/schema/condition.schema.json" },
                "reasonKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" }
              }
            }
          },
          "outcomeSummaryKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" },
          "effects": {
            "type": "array",
            "items": { "$ref": "https://new-game.local/schema/effect.schema.json" }
          },
          "grantsTags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "educationLevel": {
            "enum": ["none", "primary", "secondary", "vocational", "higher", "nightSchool"]
          },
          "careerCategory": {
            "enum": ["none", "labor", "clerical", "academic", "religious", "state", "underground", "mercantile"]
          },
          "npcOutcomes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["role"],
              "properties": {
                "role": {
                  "type": "string",
                  "minLength": 1
                },
                "educationLevel": {
                  "enum": ["none", "primary", "secondary", "vocational", "higher", "nightSchool"]
                },
                "careerCategory": {
                  "enum": ["none", "labor", "clerical", "academic", "religious", "state", "underground", "mercantile"]
                },
                "grantsTags": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "bond": { "type": "number" },
                "logKey": { "$ref": "https://new-game.local/schema/game-data.schema.json#/$defs/locKey" }
              }
            }
          }
        }
      }
    }
  }
}
