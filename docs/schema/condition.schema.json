{
  "$id": "https://new-game.local/schema/condition.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Condition",
  "$ref": "#/$defs/condition",
  "$defs": {
    "condition": {
      "type": "object",
      "oneOf": [
        { "$ref": "#/$defs/numericCondition" },
        { "$ref": "#/$defs/stringCondition" },
        { "$ref": "#/$defs/listCondition" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/condition" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/condition" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["not"],
          "properties": {
            "not": { "$ref": "#/$defs/condition" }
          }
        }
      ]
    },
    "numericCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "op", "value"],
      "properties": {
        "target": { "$ref": "#/$defs/numericTarget" },
        "op": { "enum": ["gt", "gte", "lt", "lte", "eq", "neq"] },
        "value": { "type": "number" }
      }
    },
    "stringCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "op", "value"],
      "properties": {
        "target": { "$ref": "#/$defs/stringTarget" },
        "op": { "enum": ["eq", "neq"] },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "listCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "op", "value"],
      "properties": {
        "target": { "$ref": "#/$defs/listTarget" },
        "op": { "enum": ["has", "notHas"] },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "numericTarget": {
      "anyOf": [
        {
          "enum": [
            "ageMonths",
            "money",
            "world.pressure",
            "stats.body",
            "stats.mind",
            "stats.craft",
            "stats.social",
            "stats.spirit"
          ]
        },
        {
          "type": "string",
          "pattern": "^relationship\\.(?!all\\.)([a-zA-Z0-9][a-zA-Z0-9-]*)\\.(bond|trust|dependency|conflict)$"
        }
      ]
    },
    "stringTarget": {
      "anyOf": [
        {
          "enum": [
            "educationLevel",
            "careerCategory",
            "socialClass",
            "affiliation",
            "world.region"
          ]
        },
        {
          "type": "string",
          "pattern": "^relationship\\.(?!all\\.)([a-zA-Z0-9][a-zA-Z0-9-]*)\\.(careerCategory|educationLevel|affiliation)$"
        }
      ]
    },
    "listTarget": {
      "anyOf": [
        {
          "enum": [
            "player.lifeTags",
            "player.traits",
            "world.tags"
          ]
        },
        {
          "type": "string",
          "pattern": "^relationship\\.(?!all\\.)([a-zA-Z0-9][a-zA-Z0-9-]*)\\.(lifeTags|traits)$"
        }
      ]
    }
  }
}
